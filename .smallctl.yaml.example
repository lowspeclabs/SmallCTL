endpoint: http://localhost:8000/v1
model: qwen3.5:4b
phase: explore
provider_profile: generic
run_mode: auto
reasoning_mode: auto
thinking_visibility: true
thinking_start_tag: "<thinking>"
thinking_end_tag: "</thinking>"
chat_endpoint: /chat/completions
checkpoint_on_exit: false
checkpoint_path: null
log_file: null
debug: false
max_prompt_tokens: null
reserve_completion_tokens: 1024
reserve_tool_tokens: 512
first_token_timeout_sec: null
# For LM Studio, prefer 45-60s here to avoid false first-token wedges.
healthcheck_url: null
restart_command: null
startup_grace_period_sec: 20
max_restarts_per_hour: 2
backend_healthcheck_url: null
backend_restart_command: null
backend_unload_command: null
# Example LM Studio recovery:
# provider_profile: lmstudio
# first_token_timeout_sec: 45
# Native unload is attempted automatically for LM Studio.
# backend_restart_command: "systemctl --user restart lmstudio.service"
# backend_unload_command: null
backend_healthcheck_timeout_sec: 5
backend_restart_grace_sec: 20
# ReWOO-style read-only evidence planning
tool_plan_runtime_enabled: false
tool_plan_auto_select: false
tool_plan_readonly_only: true
tool_plan_max_steps: 6
tool_plan_max_repair_attempts: 1
tool_plan_observation_token_limit: 900
tool_plan_max_observation_chars_per_step: 600
tool_plan_solver_fresh_output_limit: 1200
tool_plan_allow_web: true
tool_plan_allow_artifact_read: true
tool_plan_allow_git: false
tool_plan_fallback_to_loop_on_invalid_plan: true
tool_dag_enabled: true
tool_dag_max_parallel: 4
tool_dag_timeout_sec: 30
tool_dag_preserve_result_order: true
# Runtime-only test-time scaling for hard staged steps. Disabled by default.
test_time_scaling_enabled: false
test_time_scaling_runtimes:
  - staged_execution
test_time_scaling_trigger: retry_or_explicit
test_time_scaling_max_candidates: 3
test_time_scaling_min_candidates: 2
# Policies:
# - proposal_then_execute: generate N proposals, score cheaply, dispatch only the best.
# - first_pass: stop proposal generation when a clean candidate clears the score threshold.
# - sequential_branch: run read-only branches in parallel; keep mutating branches sequential with rollback.
test_time_scaling_policy: proposal_then_execute
test_time_scaling_strategy: diverse_nudges
test_time_scaling_score_threshold: 0.85
# Candidate proposal generation and read-only branch execution may run in parallel.
# Mutating branch execution stays sequential unless stronger isolation is added and explicitly enabled.
test_time_scaling_parallel_max: 1
test_time_scaling_timeout_sec: 120
test_time_scaling_mutating_parallel_enabled: false
# All sequential branches failed: fallback_normal_retry (default) or fail_step.
test_time_scaling_all_fail_action: fallback_normal_retry
# Larger-model escalation is advisor-only and disabled by default. It must use
# its own endpoint/model/key and never inherits the main small-model config.
escalation_enabled: false
escalation_expose_tool: true
escalation_auto_trigger: false
escalation_endpoint: null
escalation_model: null
escalation_provider_profile: auto
escalation_api_key: null
escalation_api_key_env: null
escalation_chat_endpoint: /chat/completions
escalation_max_prompt_chars: 48000
escalation_max_response_tokens: 1600
escalation_temperature: 0.2
escalation_timeout_sec: 120
escalation_max_per_task: 2
escalation_cooldown_turns: 2
escalation_repeated_failure_threshold: 2
escalation_require_tool_plan_evidence: true
escalation_redact_secrets: true
summarize_at_ratio: 0.8
recent_message_limit: 6
max_summary_items: 3
max_artifact_snippets: 4
artifact_snippet_token_limit: 400
loop_guard_enabled: true
loop_guard_stagnation_threshold: 3
loop_guard_level2_threshold: 5
loop_guard_recent_writes_limit: 5
loop_guard_tail_lines: 50
loop_guard_similarity_threshold: 0.9
loop_guard_cumulative_write_gate: true
loop_guard_checkpoint_gate: true
loop_guard_diff_gate: true
fama_enabled: true
fama_mode: lite
fama_done_gate_on_failure: true
fama_llm_judge_enabled: false
reflexion_enabled: true
reflexion_max_items: 5
reflexion_inject_top_k: 3
reflexion_persist_cross_task: false
reflexion_min_failure_severity: warning
subtask_ledger_enabled: true
subtask_max_active: 1
subtask_max_history: 12
subtask_inject_completed_limit: 3
# Opt-in native LangGraph per-node timeouts for safe async nodes. Enabled by
# default for backward compatibility; disable to fall back to the harness's
# historic timeout behavior.
langgraph_native_timeouts_enabled: true
# Opt-in native LangGraph retries for safe, idempotent prompt/retrieval nodes.
# Disabled by default; when enabled, max attempts is capped at 2.
langgraph_native_retries_enabled: false
langgraph_native_retry_max_attempts: 2
# Opt-in native LangGraph node error handlers for selected safe prompt/interpret
# nodes. Disabled by default; when enabled, prompt/interpret failures are routed
# back into the harness's recovery logic instead of ending the graph immediately.
langgraph_error_handlers_enabled: false
# Opt-in native LangGraph task/checkpoint streaming for the TUI. Disabled by
# default; when enabled, lifecycle events expose the active graph node without
# leaking prompts, tool args, or tool output.
langgraph_stream_events_enabled: false
# EXPERIMENTAL/REJECTED: Native LangGraph CachePolicy. Disabled by default and
# not implemented. No existing graph node is pure for a single run with a
# provably correct cache key: prompt preparation depends on the active
# conversation and retrieval state, and the indexer pipeline relies on LLM
# requests and mutating tool calls. Do not enable.
langgraph_cache_policy_enabled: false
