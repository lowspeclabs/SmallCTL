SMALLCTL_ENDPOINT=http://192.168.1.9:8000/v1
SMALLCTL_MODEL=openai/gpt-oss-20b
SMALLCTL_API_KEY=local-dev-key
SMALLCTL_PHASE=explore
# Supported profiles: generic, openai, ollama, vllm, lmstudio, openrouter
SMALLCTL_PROVIDER_PROFILE=generic
SMALLCTL_REASONING_MODE=auto
SMALLCTL_THINKING_VISIBILITY=true
SMALLCTL_THINKING_START_TAG=<thinking>
SMALLCTL_THINKING_END_TAG=</thinking>
SMALLCTL_CHAT_ENDPOINT=/chat/completions
SMALLCTL_CONTEXT_LIMIT=8192
SMALLCTL_CHECKPOINT_ON_EXIT=false
SMALLCTL_CHECKPOINT_PATH=
SMALLCTL_LOG_FILE=
SMALLCTL_CONFIG=
SMALLCTL_DEBUG=false
SMALLCTL_MAX_PROMPT_TOKENS=
SMALLCTL_RESERVE_COMPLETION_TOKENS=1024
SMALLCTL_RESERVE_TOOL_TOKENS=512
SMALLCTL_SUMMARIZE_AT_RATIO=0.8
SMALLCTL_RECENT_MESSAGE_LIMIT=6
SMALLCTL_MAX_SUMMARY_ITEMS=3
SMALLCTL_MAX_ARTIFACT_SNIPPETS=4
SMALLCTL_ARTIFACT_SNIPPET_TOKEN_LIMIT=400

# Larger-model escalation is disabled by default. When enabled, it uses a
# separately configured OpenAI-compatible advisor model and receives no tools.
SMALLCTL_ESCALATION_ENABLED=false
SMALLCTL_ESCALATION_EXPOSE_TOOL=true
SMALLCTL_ESCALATION_AUTO_TRIGGER=false
SMALLCTL_ESCALATION_ENDPOINT=
SMALLCTL_ESCALATION_MODEL=
SMALLCTL_ESCALATION_PROVIDER_PROFILE=auto
SMALLCTL_ESCALATION_API_KEY=
SMALLCTL_ESCALATION_API_KEY_ENV=
SMALLCTL_ESCALATION_CHAT_ENDPOINT=/chat/completions
SMALLCTL_ESCALATION_MAX_PROMPT_CHARS=48000
SMALLCTL_ESCALATION_MAX_RESPONSE_TOKENS=1600
SMALLCTL_ESCALATION_TEMPERATURE=0.2
SMALLCTL_ESCALATION_TIMEOUT_SEC=120
SMALLCTL_ESCALATION_MAX_PER_TASK=2
SMALLCTL_ESCALATION_COOLDOWN_TURNS=2
SMALLCTL_ESCALATION_REPEATED_FAILURE_THRESHOLD=2
SMALLCTL_ESCALATION_REQUIRE_TOOL_PLAN_EVIDENCE=true
SMALLCTL_ESCALATION_REDACT_SECRETS=true
