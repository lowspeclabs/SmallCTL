+def _command_has_write_or_heredoc_shape(command: str) -> bool:
+    lowered = str(command or "").strip().lower()
+    if not lowered:
+        return False
+    if "<<" in lowered:
+        return True
+    if re.search(r"(?:^|[;&|]\s*)(?:cat|printf|echo)\b[^\n;&|]*(?:>>|>)", lowered):
+        return True
+    if re.search(r"(?:^|[;&|]\s*)tee(?:\s+-a)?\s+", lowered):
+        return True
+    return False
